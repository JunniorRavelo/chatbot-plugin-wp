# MultiAI ChatBot — referencia de configuración
# WordPress no usa .env nativamente. Configura en:
#   1) Admin → MultiAI ChatBot → Modelo IA / Seguridad
#   2) wp-config.php con las constantes MULTCH_* (recomendado en producción)
#
# Solo un proveedor activo a la vez (MULTCH_PROVIDER).
#
# Gemini — elige UNA vía:
#   wordpress_ai — API key en Ajustes → Connectors; peticiones vía WordPress AI Client
#   google_ia    — API key propia (abajo); peticiones directas a Google; IDs de modelo del catálogo Connectors
#   ollama       — servidor local (sin API key en el plugin)
#
# Tratamiento de datos: el contenido del chat se envía al proveedor elegido solo cuando
# un visitante escribe en el widget. Historial/telemetría local son opt-in (General).
# Ver readme.txt (External services / Privacy) y docs/AI-PROVIDERS.md.

## Proveedor activo
# define( 'MULTCH_PROVIDER', 'wordpress_ai' );  # por defecto
# define( 'MULTCH_PROVIDER', 'google_ia' );
# define( 'MULTCH_PROVIDER', 'ollama' );

## Google IA (Gemini con API key propia — solo servidor)
# En admin: MultiAI ChatBot → Modelo IA → Google IA
# Los IDs de modelo (MULTCH_GEMINI_MODEL*) deben coincidir con los de Connectors (p. ej. gemini-2.5-flash).
define( 'MULTCH_GEMINI_API_KEY', '...' );
define( 'MULTCH_GEMINI_MODEL', 'gemini-2.5-flash' );
define( 'MULTCH_GEMINI_MODEL_CANDIDATES', 'gemini-2.5-flash-lite' );

## WordPress AI (modelo preferido; credenciales en Connectors, no aquí)
# define( 'MULTCH_MODEL', 'gemini-2.5-flash' );
# define( 'MULTCH_MODEL_CANDIDATES', 'gpt-4o-mini,claude-sonnet-4-6' );

## Ollama
# define( 'MULTCH_OLLAMA_BASE_URL', 'http://127.0.0.1:11434' );

## General
# define( 'MULTCH_STREAMING_ENABLED', true );
CHAT_STREAMING_ENABLED=true

# Allowed origins for chat endpoint (comma-separated) → MULTCH_ALLOWED_ORIGINS
CHAT_ALLOWED_ORIGINS=https://example.com,http://localhost:3000

# Cache and telemetry → MULTCH_CACHE_TTL_SECONDS, MULTCH_TELEMETRY_FILE_LOG
CHAT_CACHE_TTL_SECONDS=1800
# define( 'MULTCH_TELEMETRY_FILE_LOG', true ); // JSONL in wp-content/uploads/multiai-chatbot/

# Rate limits → MULTCH_RATE_LIMIT_*
CHAT_RATE_LIMIT_PER_MINUTE=10
CHAT_RATE_LIMIT_PER_DAY=30
CHAT_RATE_LIMIT_MODEL_PER_MINUTE=6
CHAT_RATE_LIMIT_MODEL_PER_DAY=24
CHAT_RATE_LIMIT_SOFT_THRESHOLD=0.8
CHAT_IP_SUSPEND_AFTER_VIOLATIONS=3
CHAT_IP_SUSPEND_SECONDS=900

# Internal URL used by stream → MULTCH_INTERNAL_CHAT_BASE_URL
INTERNAL_CHAT_BASE_URL=http://127.0.0.1
